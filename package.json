{
	"name": "vscode-godot-dtag",
	"displayName": "DTag",
	"description": "Syntax highlighting and diagnostics for DTag (.dtag) definition files, a Godot tag system (https://github.com/DaylilyZeleen/Godot-DTag) similar to Unreal Engine's GameplayTag",
	"version": "1.0.0",
	"publisher": "Daylily-Zeleen",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Daylily-Zeleen/VSCode-Godot-DTag"
	},
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Programming Languages",
		"Linters"
	],
	"activationEvents": [
		"onLanguage:dtag"
	],
	"main": "./out/extension.js",
	"scripts": {
		"compile": "tsc -p ./tsconfig.json",
		"watch": "tsc -watch -p ./tsconfig.json",
		"lint": "eslint src --ext ts",
		"package": "vsce package"
	},
	"devDependencies": {
		"@types/vscode": "^1.85.0",
		"typescript": "^5.3.0"
	},
	"contributes": {
		"languages": [
			{
				"id": "dtag",
				"aliases": ["DTag", "dtag"],
				"extensions": [".dtag"],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "dtag",
				"scopeName": "source.dtag",
				"path": "./syntaxes/dtag.tmLanguage.json"
			}
		]
	}
}
